<?php

declare(strict_types=1);

use Drupal\Core\Entity\ContentEntityFormInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Session\AccountInterface;
use Drupal\Core\Url;
use Drupal\profile\Entity\ProfileInterface;
use Drupal\user\UserInterface;

/**
 * Implements hook_form_alter().
 */
function profile_membership_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object instanceof ContentEntityFormInterface) {
    return;
  }

  $entity = $form_object->getEntity();
  if (!profile_membership_is_member_self_profile_edit($entity, \Drupal::currentUser())) {
    return;
  }

  if (isset($form['revision_information'])) {
    $form['revision_information']['#access'] = FALSE;
  }

  if (isset($form['revision'])) {
    $form['revision']['#access'] = FALSE;
  }

  if (isset($form['revision_log_message'])) {
    $form['revision_log_message']['#access'] = FALSE;
  }

  if (isset($form['actions']['submit']['#submit']) && is_array($form['actions']['submit']['#submit'])) {
    $form['actions']['submit']['#submit'][] = 'profile_membership_force_member_self_edit_revision';
  }

  // Billing-state fields. `field_membership_type` is authoritatively written
  // by Chargebee (chargebee_status_sync PlanManager on every webhook, plus
  // the chargebee_fetch_data batch sync) and a member changing it via this
  // form could set themselves to a cheaper/free plan until the next webhook
  // re-syncs it — and in the meantime any logic keying off membership type
  // would be wrong. `field_member_payment_method` feeds the Finance
  // "Payment Mix" dashboard chart and has no automated writer, so a member
  // silently flipping it would corrupt reporting outright. View displays
  // already hide both fields; this closes the matching edit-form leak.
  // Staff/admin profile edits and Chargebee sync are unaffected — they
  // don't go through the member self-edit path this alter scopes to.
  foreach (['field_membership_type', 'field_member_payment_method'] as $billing_field) {
    if (isset($form[$billing_field])) {
      $form[$billing_field]['#access'] = FALSE;
    }
  }

  // Staff-only field groups (Operations, Payment, End, Advanced) render on the
  // member self-edit form as collapsed fieldsets of editable staff data:
  // membership/offboarding dates, payment status, awards, Slack IDs, staff
  // notes. A member has no reason to edit any of it, and onboarding members
  // were shown the entire staff apparatus while trying to finish a short
  // profile (funnel review 2026-07-17). Hide these for anyone who can't
  // administer profiles, so staff editing their own profile keep full access.
  // field_group drops a fieldset once all its children are inaccessible.
  if (!\Drupal::currentUser()->hasPermission('administer profile')) {
    $staff_fields = [
      // Operations.
      'field_member_reactivation_date', 'field_member_access', 'field_member_slack_id_number',
      // Payment (membership type + payment method already hidden above).
      'field_member_scheduled_end', 'field_member_payment_monthly', 'field_member_payment_contact',
      'field_member_household_primary', 'field_member_payment_status', 'field_member_notes',
      // End.
      'field_member_end_date', 'field_member_end_reason', 'field_member_end_reason_notes',
      // Advanced.
      'field_member_awards', 'field_member_interests', 'field_member_legacy_username',
    ];
    foreach ($staff_fields as $staff_field) {
      if (isset($form[$staff_field])) {
        $form[$staff_field]['#access'] = FALSE;
      }
    }
  }

  // The address field was deprecated for CiviCRM and removed from this form
  // (commit 6dc3268f42). Members still come here looking for it, so point
  // them at the dedicated self-service page. Placed at the top so it's the
  // first thing a member hunting for "address" sees.
  $form['profile_membership_address_moved'] = [
    '#type' => 'container',
    '#weight' => -100,
    '#attributes' => ['class' => ['messages', 'messages--status']],
    'content' => [
      '#markup' => '<strong>' . t('Need to update your mailing address?') . '</strong> '
      . t('Address is now managed on its own page: <a href=":url">Update your mailing address</a>.', [
        ':url' => Url::fromRoute('profile_membership.update_address')->toString(),
      ]),
    ],
  ];
}

/**
 * Forces revisions for members editing their own main profile.
 */
function profile_membership_force_member_self_edit_revision(array $form, FormStateInterface $form_state): void {
  $form_object = $form_state->getFormObject();
  if (!$form_object instanceof ContentEntityFormInterface) {
    return;
  }

  $entity = $form_object->getEntity();
  if (!profile_membership_is_member_self_profile_edit($entity, \Drupal::currentUser())) {
    return;
  }

  assert($entity instanceof ProfileInterface);
  $entity->setNewRevision(TRUE);
  $entity->setRevisionLogMessage('Member updated their own profile.');
}

/**
 * Implements hook_makerspace_user_links_links().
 *
 * Surfaces the self-service "Update Mailing Address" link on a member's own
 * user page. The address itself lives in CiviCRM (the Drupal profile field was
 * deprecated for CiviCRM); this link is the member-facing entry point.
 */
function profile_membership_makerspace_user_links_links(UserInterface $account, AccountInterface $viewer, string $audience = 'admin'): array {
  if ($audience !== 'member' || (int) $account->id() !== (int) $viewer->id()) {
    return [];
  }

  return [
    [
      'id' => 'update_mailing_address',
      // UserLinkManager::collectLinks() filters by this key (defaults to
      // 'admin' when absent), so it must be set explicitly.
      'audience' => 'member',
      'title' => t('Update Mailing Address'),
      'route_name' => 'profile_membership.update_address',
      'category' => t('Quick Links'),
      'weight' => -85,
      'description' => t('Update the mailing address we have on file.'),
    ],
  ];
}

/**
 * Implements hook_entity_insert().
 */
function profile_membership_entity_insert(EntityInterface $entity): void {
  profile_membership_maybe_send_entrepreneurship_email($entity);
}

/**
 * Implements hook_entity_update().
 */
function profile_membership_entity_update(EntityInterface $entity): void {
  profile_membership_maybe_send_entrepreneurship_email($entity);
}

/**
 * Sends an entrepreneurship follow-up email when profile selections match.
 */
function profile_membership_maybe_send_entrepreneurship_email(EntityInterface $entity): void {
  if (!$entity instanceof ProfileInterface || $entity->bundle() !== 'main') {
    return;
  }

  $config = \Drupal::config('profile_membership.settings');
  if (!$config->get('entrepreneurship_email_enabled')) {
    return;
  }

  $goal_values = profile_membership_get_list_values($entity, 'field_member_goal');
  $entrepreneurship_values = profile_membership_get_list_values($entity, 'field_member_entrepreneurship');
  $all_values = array_unique(array_merge($goal_values, $entrepreneurship_values));

  $trigger_goals = (array) $config->get('trigger_goal_values');
  $trigger_entrepreneurship = (array) $config->get('trigger_entrepreneurship_values');
  $trigger_values = array_unique(array_merge($trigger_goals, $trigger_entrepreneurship));

  if (!$trigger_values || !array_intersect($all_values, $trigger_values)) {
    return;
  }

  $account = $entity->getOwner();
  if (!$account || !$account->id()) {
    return;
  }

  $to = (string) $account->getEmail();
  if ($to === '') {
    return;
  }

  $user_data = \Drupal::service('user.data');
  if ($config->get('send_once') && $user_data->get('profile_membership', $account->id(), 'entrepreneurship_invite_sent')) {
    return;
  }

  $subject = (string) $config->get('entrepreneurship_email_subject');
  $body_template = (string) $config->get('entrepreneurship_email_body');
  $regional_support_url = (string) $config->get('regional_support_url');

  $site_name = (string) \Drupal::config('system.site')->get('name');
  $variables = [
    '[user:display-name]' => $account->getDisplayName(),
    '[user:mail]' => $to,
    '[site:name]' => $site_name,
    '[regional_support_url]' => $regional_support_url,
  ];

  $body = strtr($body_template, $variables);
  $langcode = $account->getPreferredLangcode() ?: 'en';
  $from = (string) \Drupal::config('system.site')->get('mail');

  $params = [
    'subject' => strtr($subject, $variables),
    'body' => $body,
  ];

  $result = \Drupal::service('plugin.manager.mail')->mail(
    'profile_membership',
    'entrepreneurship_invite',
    $to,
    $langcode,
    $params,
    $from,
    TRUE
  );

  if (!empty($result['result'])) {
    if ($config->get('send_once')) {
      $user_data->set('profile_membership', $account->id(), 'entrepreneurship_invite_sent', \Drupal::time()->getCurrentTime());
    }
    \Drupal::logger('profile_membership')->notice('Entrepreneurship follow-up email sent to user @uid.', ['@uid' => $account->id()]);
  }
  else {
    \Drupal::logger('profile_membership')->error('Failed to send entrepreneurship follow-up email to user @uid.', ['@uid' => $account->id()]);
  }
}

/**
 * Extracts string values from a list field.
 */
function profile_membership_get_list_values(ProfileInterface $profile, string $field_name): array {
  if (!$profile->hasField($field_name)) {
    return [];
  }
  $items = $profile->get($field_name)->getValue();
  if (empty($items)) {
    return [];
  }
  return array_values(array_filter(array_map(static fn(array $item): string => (string) ($item['value'] ?? ''), $items)));
}

/**
 * Implements hook_mail().
 */
function profile_membership_mail(string $key, array &$message, array $params): void {
  if ($key !== 'entrepreneurship_invite') {
    return;
  }
  $message['subject'] = (string) ($params['subject'] ?? '');
  $message['body'][] = (string) ($params['body'] ?? '');
}

/**
 * Checks whether the current edit is a member editing their own main profile.
 */
function profile_membership_is_member_self_profile_edit(EntityInterface $entity, AccountInterface $account): bool {
  if (!$entity instanceof ProfileInterface || $entity->bundle() !== 'main') {
    return FALSE;
  }

  // Onboarding members (member_pending_approval) edit this same form to
  // complete their profile, so they get the same self-edit trimming as full
  // members — otherwise they see the entire staff apparatus mid-signup.
  if ($account->isAnonymous()
    || !($account->hasRole('member') || $account->hasRole('member_pending_approval'))) {
    return FALSE;
  }

  $owner = $entity->getOwner();
  return $owner && (int) $owner->id() === (int) $account->id();
}
